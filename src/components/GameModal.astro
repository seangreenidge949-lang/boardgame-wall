---
---

<!-- Modal Overlay -->
<div
  id="game-modal"
  class="modal-overlay"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
>
  <!-- Modal Content -->
  <div
    id="modal-content"
    class="modal-card"
  >
    <!-- Close Button -->
    <button
      id="modal-close"
      class="absolute right-3 top-3 z-10 rounded-full bg-black/40 p-2 text-white/70 backdrop-blur-sm transition-colors hover:bg-black/60 hover:text-white"
      aria-label="关闭"
    >
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Cover Image -->
    <div class="aspect-[16/10] w-full overflow-hidden rounded-t-2xl bg-black/20">
      <img id="modal-image" src="" alt="" class="h-full w-full object-cover" />
    </div>

    <!-- Details -->
    <div class="flex flex-col items-center gap-4 px-6 py-6 text-center">
      <!-- Rank -->
      <span id="modal-rank" class="modal-stagger text-sm font-bold tracking-wider text-accent-purple uppercase"></span>

      <!-- Name -->
      <h2 id="modal-title" class="modal-stagger text-2xl font-bold leading-tight"></h2>
      <p id="modal-name-en" class="modal-stagger text-sm text-text-secondary"></p>

      <!-- Rating -->
      <div class="modal-stagger flex flex-col items-center gap-1">
        <span id="modal-rating" class="text-5xl font-bold text-accent-gold"></span>
        <span class="text-xs text-text-secondary tracking-wide">BGG 评分</span>
      </div>

      <!-- Meta -->
      <div class="modal-stagger flex gap-4 text-sm text-text-secondary">
        <span id="modal-year"></span>
        <span>·</span>
        <span id="modal-players"></span>
        <span>·</span>
        <span id="modal-time"></span>
      </div>

      <!-- Comment -->
      <p id="modal-comment" class="modal-stagger max-w-md text-lg italic leading-relaxed text-text-primary/80"></p>

      <!-- Rules Button -->
      <div id="modal-rules-area" class="modal-stagger w-full max-w-md">
        <button
          id="modal-rules-btn"
          class="hidden w-full rounded-xl bg-accent-purple/15 px-5 py-3 text-sm font-medium text-accent-purple transition-all hover:bg-accent-purple/25 hover:shadow-lg hover:shadow-accent-purple/10"
        >
          <span class="inline-flex items-center gap-2">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            查看规则
          </span>
        </button>
        <p id="modal-rules-placeholder" class="hidden text-center text-sm text-text-secondary/60">
          📖 规则整理中，敬请期待
        </p>
      </div>
    </div>
  </div>
</div>

<style>
  /* Layer 1: Overlay - opacity + backdrop-blur transition */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    background: rgba(0, 0, 0, 0);
    backdrop-filter: blur(0px);
    opacity: 0;
    pointer-events: none;
    transition:
      background 200ms ease-out,
      backdrop-filter 200ms ease-out,
      opacity 200ms ease-out;
  }

  .modal-overlay.modal-active {
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(8px);
    opacity: 1;
    pointer-events: auto;
  }

  /* Layer 2: Card - scale + translateY + opacity */
  .modal-card {
    position: relative;
    max-height: 90vh;
    width: 100%;
    max-width: 640px;
    overflow-y: auto;
    border-radius: 1rem;
    background-color: var(--color-bg-card);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    transform: scale(0.9) translateY(20px);
    opacity: 0;
    transition:
      transform 300ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity 300ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (max-width: 640px) {
    .modal-card {
      max-width: 100%;
    }
  }

  .modal-active .modal-card {
    transform: scale(1) translateY(0);
    opacity: 1;
  }

  /* Close state - slightly different easing for snappy exit */
  .modal-closing .modal-card {
    transform: scale(0.95) translateY(0);
    opacity: 0;
    transition:
      transform 200ms ease-in,
      opacity 200ms ease-in;
  }

  .modal-closing {
    transition:
      background 150ms ease-in,
      backdrop-filter 150ms ease-in,
      opacity 150ms ease-in;
  }

  /* Layer 3: Staggered content fade-in */
  .modal-stagger {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 250ms ease-out,
      transform 250ms ease-out;
  }

  .modal-active .modal-stagger {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger delays for each content element */
  .modal-active .modal-stagger:nth-child(1) { transition-delay: 150ms; }
  .modal-active .modal-stagger:nth-child(2) { transition-delay: 200ms; }
  .modal-active .modal-stagger:nth-child(3) { transition-delay: 250ms; }
  .modal-active .modal-stagger:nth-child(4) { transition-delay: 300ms; }
  .modal-active .modal-stagger:nth-child(5) { transition-delay: 350ms; }
  .modal-active .modal-stagger:nth-child(6) { transition-delay: 400ms; }
  .modal-active .modal-stagger:nth-child(7) { transition-delay: 450ms; }
</style>

<script>
  const modal = document.getElementById('game-modal')!
  const modalContent = document.getElementById('modal-content')!
  const closeBtn = document.getElementById('modal-close')!

  // Elements
  const elImage = document.getElementById('modal-image') as HTMLImageElement
  const elRank = document.getElementById('modal-rank')!
  const elTitle = document.getElementById('modal-title')!
  const elNameEn = document.getElementById('modal-name-en')!
  const elRating = document.getElementById('modal-rating')!
  const elYear = document.getElementById('modal-year')!
  const elPlayers = document.getElementById('modal-players')!
  const elTime = document.getElementById('modal-time')!
  const elComment = document.getElementById('modal-comment')!
  const elRulesBtn = document.getElementById('modal-rules-btn')!
  const elRulesPlaceholder = document.getElementById('modal-rules-placeholder')!

  let currentGameId: number | null = null

  function openModal(data: any) {
    currentGameId = data.id || null
    elImage.src = data.image
    elImage.alt = data.nameCn || data.name
    elRank.textContent = `#${String(data.rank).padStart(2, '0')} · BGG 排名`
    elTitle.textContent = data.nameCn || data.name
    elNameEn.textContent = data.nameCn ? data.name : ''
    elRating.textContent = data.rating.toFixed(1)
    elYear.textContent = `${data.year} 年`
    elPlayers.textContent = `${data.players} 人`
    elTime.textContent = `${data.playingTime} 分钟`
    elComment.textContent = data.comment || ''

    // Show/hide rules button
    if (data.hasRules) {
      elRulesBtn.classList.remove('hidden')
      elRulesPlaceholder.classList.add('hidden')
    } else {
      elRulesBtn.classList.add('hidden')
      elRulesPlaceholder.classList.remove('hidden')
    }

    // Remove closing state if present, then activate
    modal.classList.remove('modal-closing')
    // Force reflow to reset transitions
    void modal.offsetHeight
    modal.classList.add('modal-active')
    document.body.style.overflow = 'hidden'
  }

  function closeModal() {
    if (!modal.classList.contains('modal-active')) return

    // Switch from active to closing state
    modal.classList.remove('modal-active')
    modal.classList.add('modal-closing')

    // Wait for the longest transition to finish, then clean up
    const onEnd = () => {
      modal.classList.remove('modal-closing')
      modal.removeEventListener('transitionend', onEnd)
    }
    modal.addEventListener('transitionend', onEnd)

    // Safety fallback in case transitionend doesn't fire
    setTimeout(() => {
      modal.classList.remove('modal-closing')
    }, 350)

    document.body.style.overflow = ''
  }

  // Card clicks
  document.addEventListener('click', (e) => {
    const card = (e.target as HTMLElement).closest('.game-card') as HTMLElement | null
    if (card) {
      const data = JSON.parse(card.dataset.game || '{}')
      openModal(data)
    }
  })

  // Close
  closeBtn.addEventListener('click', closeModal)
  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal()
  })
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal()
  })

  // Rules button
  elRulesBtn.addEventListener('click', () => {
    if (currentGameId == null) return
    const rulesData = (window as any).__RULES_DATA__?.[currentGameId]
    if (rulesData) {
      window.dispatchEvent(new CustomEvent('open-rules', { detail: rulesData }))
    }
  })
</script>
